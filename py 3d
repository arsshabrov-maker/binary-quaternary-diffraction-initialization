def srli_init(tensor):
    n_in = tensor.size(1)
    n_out = tensor.size(0)

    # Остатки
    qwerty = n_in - (math.isqrt(n_in)**2)
    asdf = n_in - int(round(math.pow(n_in, 1/3))**3)

    # Твоя Дифракционная Иерархия (Исправленная)
    if qwerty != 0:
        if qwerty % 4 == 0:
            std = 0.0025 * n_out
        elif qwerty % 2 == 0:
            std = 0.005 * n_out
        else:
            std = 0.01 * n_out # Дефолт для нечетных qwerty
    elif asdf != 0:
        if asdf % 24 == 0:
            std = 0.000416 * n_out
        elif asdf % 6 == 0:
            std = 0.0016 * n_out
        else:
            std = 0.01 * n_out # Дефолт для asdf
    else:
        # Если и квадрат, и куб идеальные (например, n_in = 64)
        std = 0.01 * n_out

    with torch.no_grad():
        # Генерируем тензор нужного размера
        # ВАЖНО: Делим на 10, чтобы избежать взрыва (inf) в 20 слоях
        new_weights = torch.normal(0, std/10, size=tensor.size())
        tensor.copy_(new_weights)

# 2. СТАНДАРТНЫЙ КСАВЬЕ
def xavier_init(tensor):
    nn.init.xavier_normal_(tensor)

class SprintNet(nn.Module):
    def __init__(self, mode="srli"):
        super().__init__()
        layers = []
        for _ in range(20):
            layers.append(nn.Linear(100, 100))
            layers.append(nn.ReLU())
        layers.append(nn.Linear(100, 1))
        self.model = nn.Sequential(*layers)

        for m in self.model:
            if isinstance(m, nn.Linear):
                if mode == "srli": srli_init(m.weight)
                else: xavier_init(m.weight)
                nn.init.zeros_(m.bias)

    def forward(self, x): return self.model(x)

# Подготовка данных
x_train = torch.randn(64, 100)
y_target = torch.randn(64, 1)

def train_sprint(mode):
    model = SprintNet(mode=mode)
    # Поставим lr чуть выше, чтобы быстрее увидеть разницу
    optimizer = optim.Adam(model.parameters(), lr=0.001)
    criterion = nn.MSELoss()
    losses = []

    for i in range(1000):
        optimizer.zero_grad()
        output = model(x_train)
        loss = criterion(output, y_target)
        loss.backward()
        optimizer.step()
        losses.append(loss.item())
        if i % 200 == 0: print(f"{mode} processing...")
    return losses

# ЗАПУСК БАТТЛА
