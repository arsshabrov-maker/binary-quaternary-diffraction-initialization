import torch
import torch.nn as nn
import math
import matplotlib.pyplot as plt

def my_custom_init(tensor):
    n_in = tensor.size(1)
    n_out = tensor.size(0)

    # Остатки
    qwerty = n_in - (math.isqrt(n_in)**2)
    asdf = n_in - int(round(math.pow(n_in, 1/3))**3)

    # Твоя Дифракционная Иерархия (Исправленная)
    if qwerty != 0:
        if qwerty % 4 == 0:
            std = 0.0025 * n_out
        elif qwerty % 2 == 0:
            std = 0.005 * n_out
        else:
            std = 0.01 * n_out # Дефолт для нечетных qwerty
    elif asdf != 0:
        if asdf % 24 == 0:
            std = 0.000416 * n_out
        elif asdf % 6 == 0:
            std = 0.0016 * n_out
        else:
            std = 0.01 * n_out # Дефолт для asdf
    else:
        # Если и квадрат, и куб идеальные (например, n_in = 64)
        std = 0.01 * n_out

    with torch.no_grad():
        # Ограничиваем std/10 для стабильности в глубоких сетях
        return tensor.normal_(0, std / 10)

def xavier_manual_init(tensor):
    n_in = tensor.size(1)
    n_out = tensor.size(0)
    std = math.sqrt(2.0 / (n_in + n_out))
    with torch.no_grad():
        return tensor.normal_(0, std)

class DeepProbeNet(nn.Module):
    def __init__(self, mode="xavier"):
        super().__init__()
        layers = []
        for _ in range(20):
            layers.append(nn.Linear(100, 100))
            layers.append(nn.ReLU())
        self.model = nn.Sequential(*layers)

        for m in self.model:
            if isinstance(m, nn.Linear):
                if mode == "xavier": xavier_manual_init(m.weight)
                else: my_custom_init(m.weight)
                nn.init.zeros_(m.bias)

    def forward(self, x):
        activations = []
        for layer in self.model:
            x = layer(x)
            if isinstance(layer, nn.ReLU):
                activations.append(x.std().item())
        return activations

# --- ТЕСТ ---
x = torch.randn(1, 100)
std_xavier = DeepProbeNet(mode="xavier")(x)
std_custom = DeepProbeNet(mode="custom")(x)

plt.figure(figsize=(10, 5))
plt.plot(std_xavier, label='Xavier Math', marker='o')
